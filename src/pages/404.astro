---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
const logoUrl = `${base}images/logos/komizo-logo.png`;
---

<BaseLayout title="Page introuvable | Komizo Partners">
  <main class="flex min-h-screen items-center justify-center px-6">
    <div class="text-center max-w-md">
      <img src={logoUrl} alt="Komizo Partners" width="140" height="50" class="h-10 w-auto mx-auto mb-8 opacity-80" />
      <p class="text-6xl font-bold text-marine-800">404</p>
      <p class="mt-4 text-lg text-marine-800/70">Cette page n'existe pas ou a été déplacée.</p>
      <a href={base} class="btn btn-primary mt-8 inline-flex">Retour à l'accueil</a>
    </div>
  </main>
</BaseLayout>
