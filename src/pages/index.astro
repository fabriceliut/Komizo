---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Section from '../components/Section.astro';
import TeamGrid from '../components/TeamGrid.astro';
import ContactForm from '../components/ContactForm.astro';

const base = import.meta.env.BASE_URL;
const heroImage = `${base}images/hero/hero-bg.jpg`;
const logoUrl = `${base}images/logos/komizo-logo-blanc.png`;

const references = [
  {
    sector: 'ETI — Aide à domicile',
    detail: 'Leader français, 10 000 salariés, accompagnée par des fonds de private equity',
    enjeu: 'Accompagnement à la transformation en société à mission (depuis 2022)',
    intervention: 'Animation d\'un groupe RSE, co-construction d\'une raison d\'être et d\'engagements stratégiques, structuration business x ESG 360°',
    resultat: 'Amélioration du bien-être des auxiliaires de vie (73% → 78%), baisse significative du turnover et de l\'absentéisme',
    verbatim: 'L\'accompagnement de Komizo a été un catalyseur essentiel pour nous, non seulement dans notre engagement à devenir une référence en matière d\'aide à domicile, mais aussi dans notre transformation en société à mission. Komizo nous challenge beaucoup, et ce de manière intelligente : c\'est ce qu\'on aime !',
    auteur: 'Président'
  },
  {
    sector: 'PME industrielle — Leader mondial',
    detail: '250 salariés, production de gants de boîtes à gants, sous private equity',
    enjeu: 'Accompagnement à la transformation durable (depuis 2023)',
    intervention: 'Sensibilisation à tous les niveaux, structuration de la politique RSE, création et animation d\'un comité RSE',
    resultat: 'Réduction de 29% de l\'intensité carbone, développement de l\'éco-conception, embarquement de la filiale US',
    verbatim: 'Komizo est un v\u00e9ritable catalyseur de la transformation environnementale et sociale. Leur approche nous aide \u00e0 structurer notre strat\u00e9gie RSE de mani\u00e8re concr\u00e8te et pragmatique. La combinaison de nos \u00e9nergies nous insuffle un dynamisme puissant et inspirant pour motiver l\'ensemble des collaborateurs, y compris notre filiale am\u00e9ricaine.',
    auteur: 'Directrice QHSE et RSE'
  },
  {
    sector: 'Private equity — 4 Mds€ sous gestion',
    detail: 'Acteur indépendant du capital-investissement',
    enjeu: 'Accompagnement opérationnel du fonds ETI (depuis 2023)',
    intervention: 'Operating Partner ESG externalisé pour dix participations, depuis le sourcing jusqu\'à l\'exit',
    resultat: 'Création de valeur durable, meilleur pilotage des risques et opportunités',
    verbatim: 'Komizo travaille avec nous en tant que référent ESG opérationnel pour dix de nos participations. Leur approche est engagée, pragmatique et business. Ils interviennent depuis le sourcing jusqu\'au suivi opérationnel. Komizo travaille comme partenaire de confiance, avec un vrai rôle d\'Operating Partner externalisé.',
    auteur: 'Partner'
  },
  {
    sector: 'Infrastructures durables — 20 Mds€ sous gestion',
    detail: 'Société d\'investissement indépendante spécialisée',
    enjeu: 'Création et déploiement d\'une société de projet à impact (depuis 2023)',
    intervention: 'Chefferie de projet d\'un consortium public-privé, rôle de Direction du développement',
    resultat: 'Lancement opérationnel de la société de projet',
    verbatim: 'Grâce aux compétences économico-financières de Corentin, à son énergie communicative et à sa capacité à animer un projet collectif, nous sommes proches du lancement opérationnel de ce projet particulièrement difficile et ambitieux.',
    auteur: 'Directeur de l\'investissement local et durable'
  },
  {
    sector: 'Fonds early-stage — 700M€ sous gestion',
    detail: 'Fonds d\'investissement européen',
    enjeu: 'Création et déploiement d\'un fonds à impact (depuis 2019)',
    intervention: 'Lead sur la réponse à appel d\'offres (remporté), structuration du fonds, Operating Partner Impact',
    resultat: 'Gain de l\'appel d\'offres, développement de la thématique impact x santé (près de 100 M€ sous gestion)',
    verbatim: 'L\'implication de Corentin a été précieuse dès la phase de l\'appel d\'offres. Corentin nous a accompagné dans l\'analyse d\'opportunités d\'investissement, la construction et le suivi de feuilles de route impact.',
    auteur: 'Directeur Général Délégué'
  }
];

const engagements = [
  'Mesurer la progression de chaque client·e — avant, pendant, après — et publier les résultats dans notre rapport de mission annuel',
  'Accompagner chaque client·e pour que l\'impact soit à l\'ordre du jour du board et des équipes, pas seulement dans un rapport',
  'Faire monter en compétences nos client·es sur les sujets clés — notre objectif n\'est pas d\'être indispensables, mais de les rendre autonomes',
  'Prendre soin de notre équilibre pour durer — sans équipe solide, pas d\'accompagnement de qualité',
  'Zéro vol en Europe pour nos déplacements',
  'Reverser 2 % de notre CA à des associations — 12 projets soutenus depuis 2022 pour 29 300 € de dons',
  'Réinvestir 20 % de notre résultat net dans des startups à impact — 4 entreprises accompagnées à ce jour (20 025 € investis, 1 sortie)',
  'Organiser au moins un événement collectif par an pour essaimer au-delà de nos missions',
];
---

<BaseLayout>
  <Header />

  <main id="main-content" class="pt-16">

    <!-- HERO -->
    <section id="hero" class="section-anchor relative bg-marine-800 py-28 sm:py-36 overflow-hidden">
      <div class="absolute inset-0" aria-hidden="true">
        <img src={heroImage} alt="" class="h-full w-full object-cover opacity-25" />
        <div class="absolute inset-0 bg-gradient-to-r from-marine-800/90 via-marine-800/70 to-marine-800/50"></div>
      </div>
      <div class="relative mx-auto w-full max-w-6xl px-6 lg:px-10">
        <div class="reveal max-w-3xl">
          <img src={logoUrl} alt="Komizo Partners" width="200" height="70" class="h-12 w-auto mb-10 opacity-90" />
          <h1 class="text-4xl sm:text-5xl lg:text-6xl text-white font-bold leading-[1.1]">
            Des PME solides<br />dans un monde instable
          </h1>
          <p class="mt-8 max-w-2xl text-lg sm:text-xl text-white/75 leading-relaxed">
            Nous accompagnons les équipes dirigeantes et d'investissement sur le long cours — pour réconcilier performance financière, transformation durable et ancrage dans le vivant.
          </p>
          <div class="mt-12 flex flex-wrap gap-4">
            <a href="#contact" class="btn btn-primary text-base px-8 py-4">Nous contacter</a>
            <a href="#collectif" class="btn btn-secondary border-white/30 text-white hover:bg-white/10 hover:border-white text-base px-8 py-4">Rejoindre notre collectif</a>
          </div>
        </div>
      </div>
    </section>

    <!-- BANDE LOGOS CONFIANCE -->
    <div class="bg-white border-b border-gris-200">
      <div class="mx-auto w-full max-w-6xl px-6 lg:px-10 py-8">
        <p class="text-[11px] font-semibold uppercase tracking-widest text-gris-400 text-center mb-6">Ils nous font confiance</p>
        <div class="flex flex-wrap items-center justify-center gap-8 sm:gap-12">
          <img src={`${base}images/logos/clients/siparex.svg`} alt="Siparex" class="h-7 sm:h-8 w-auto grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all duration-300" loading="lazy" />
          <img src={`${base}images/logos/clients/meridiam.png`} alt="Meridiam" class="h-7 sm:h-8 w-auto grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all duration-300" loading="lazy" />
          <img src={`${base}images/logos/clients/inco-ventures.png`} alt="INCO Ventures" class="h-7 sm:h-8 w-auto grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all duration-300" loading="lazy" />
          <img src={`${base}images/logos/clients/evolem.svg`} alt="Evolem" class="h-7 sm:h-8 w-auto grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all duration-300" loading="lazy" />
          <img src={`${base}images/logos/clients/winncare.svg`} alt="Winncare" class="h-7 sm:h-8 w-auto grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all duration-300" loading="lazy" />
          <img src={`${base}images/logos/clients/destia.svg`} alt="Destia" class="h-7 sm:h-8 w-auto grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all duration-300" loading="lazy" />
          <img src={`${base}images/logos/clients/epsa.svg`} alt="EPSA" class="h-7 sm:h-8 w-auto grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all duration-300" loading="lazy" />
          <img src={`${base}images/logos/clients/mutualite-francaise.svg`} alt="Mutualité Française" class="h-7 sm:h-8 w-auto grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all duration-300" loading="lazy" />
        </div>
      </div>
    </div>

    <!-- À PROPOS -->
    <Section id="apropos" title="Qui sommes-nous" tone="default">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2">
        <div class="space-y-5 text-base sm:text-lg reveal">
          <p>
            <strong class="text-marine-800">Komizo</strong> est une société à mission à taille humaine, née en 2022 et basée à Lyon.
            Notre raison d'être est de <strong>mettre l'économie et la finance au service du vivant</strong>.
          </p>
          <p>
            Komizo accompagne des PME-ETI, sociétés de gestion et projets à impact de manière
            stratégique et opérationnelle en (ré)intégrant les enjeux écologiques et sociaux au
            cœur de leurs activités.
          </p>
          <p>
            Partenaires de confiance sur la durée, nous facilitons la conduite du changement à
            tous les niveaux, de manière concrète et pragmatique, en nous adaptant au contexte de
            chacun et en favorisant la coopération en interne et avec l'écosystème.
          </p>
          <p class="text-sm italic text-marine-800/60">
            Komizo signifie « prendre soin » en grec ancien.
          </p>
          <div class="flex flex-wrap gap-2 mt-2">
            <span class="inline-flex items-center rounded-full bg-marine-800/5 px-3 py-1 text-xs font-medium text-marine-800">Écoute active</span>
            <span class="inline-flex items-center rounded-full bg-marine-800/5 px-3 py-1 text-xs font-medium text-marine-800">Non dogmatique</span>
            <span class="inline-flex items-center rounded-full bg-marine-800/5 px-3 py-1 text-xs font-medium text-marine-800">Apporteurs de sens</span>
            <span class="inline-flex items-center rounded-full bg-marine-800/5 px-3 py-1 text-xs font-medium text-marine-800">Bousculeurs bienveillants</span>
          </div>

        </div>

        <div class="reveal" style="--delay:120ms">
          <div class="rounded-2xl bg-vert-100 p-8">
            <h3 class="text-xl font-semibold text-marine-800 mb-4">Ce qui nous distingue</h3>
            <p class="text-marine-800/70">
              Contrairement aux cabinets classiques, nous intervenons généralement en immersion — une à deux journées par semaine, sur plusieurs années, à la frontière de la finance et de l'opérationnel — avec un interlocuteur senior dédié, appuyé par un collectif de freelances spécialisés.
            </p>
          </div>

          <div class="mt-6 rounded-2xl border border-gris-200 p-8">
            <h3 class="text-xl font-semibold text-marine-800 mb-4">Nos engagements</h3>
            <ul class="space-y-3">
              {engagements.map(text => (
                <li class="flex items-start gap-3 text-sm text-marine-800/70">
                  <svg class="w-5 h-5 flex-shrink-0 text-vert-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{text}</span>
                </li>
              ))}
            </ul>

            <a href="#" class="inline-flex items-center gap-2 text-vert-600 font-medium no-underline hover:text-vert-500 mt-6 text-sm">
              Découvrir notre rapport de mission 2024 →
            </a>
          </div>
        </div>
      </div>

      <!-- ASSOCIATIONS & STARTUPS — section pleine largeur -->
      <div class="mt-14 reveal">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
          <!-- Associations soutenues -->
          <div class="rounded-2xl border border-gris-200 bg-white p-6 sm:p-8">
            <p class="text-xs font-semibold uppercase tracking-wide text-marine-800/50 mb-5">Associations soutenues</p>
            <div class="flex flex-wrap items-center gap-5">
              <img src={`${base}images/logos/associations/campus-transition.png`} alt="Campus de la Transition" class="h-10 w-auto" loading="lazy" />
              <img src={`${base}images/logos/associations/terre-de-milpa.png`} alt="Terre de Milpa" class="h-10 w-auto" loading="lazy" />
              <img src={`${base}images/logos/associations/h-up.png`} alt="H'up" class="h-10 w-auto" loading="lazy" />
              <img src={`${base}images/logos/associations/ville-a-velo.svg`} alt="La Ville à Vélo" class="h-10 w-auto" loading="lazy" />
              <img src={`${base}images/logos/associations/sport-dans-la-ville.svg`} alt="Sport dans la Ville" class="h-10 w-auto" loading="lazy" />
            </div>
            <p class="text-xs text-marine-800/40 mt-4 italic">12 projets soutenus depuis 2022</p>
          </div>

          <!-- Startups à impact -->
          <div class="rounded-2xl border border-gris-200 bg-white p-6 sm:p-8">
            <p class="text-xs font-semibold uppercase tracking-wide text-marine-800/50 mb-5">Startups à impact accompagnées</p>
            <div class="flex flex-wrap items-center gap-4">
              <div class="h-10 px-4 rounded-lg bg-gris-100 flex items-center justify-center">
                <span class="text-xs text-marine-800/40">Logo 1</span>
              </div>
              <div class="h-10 px-4 rounded-lg bg-gris-100 flex items-center justify-center">
                <span class="text-xs text-marine-800/40">Logo 2</span>
              </div>
              <div class="h-10 px-4 rounded-lg bg-gris-100 flex items-center justify-center">
                <span class="text-xs text-marine-800/40">Logo 3</span>
              </div>
              <div class="h-10 px-4 rounded-lg bg-gris-100 flex items-center justify-center">
                <span class="text-xs text-marine-800/40">Logo 4</span>
              </div>
            </div>
            <p class="text-xs text-marine-800/40 mt-4 italic">4 entreprises accompagnées à ce jour</p>
          </div>
        </div>
      </div>
    </Section>

    <!-- OFFRES -->
    <Section id="offres" title="Nos offres" subtitle="Deux expertises complémentaires au service de la transformation durable" tone="muted">
      <div class="grid grid-cols-1 gap-8 lg:grid-cols-2 items-stretch">

        <!-- Offre Dirigeants -->
        <article class="card reveal p-8 flex flex-col transition-shadow duration-300 hover:shadow-soft">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-vert-200 mb-4">
            <svg class="w-6 h-6 text-marine-800" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-marine-800">Transformation durable et performance</h3>
          <p class="mt-2 text-sm font-medium text-vert-600">Pour les dirigeants de PME-ETI</p>
          <p class="mt-4 text-marine-800/70">
            Dirigeants de PME ou ETI en phase de transformation, croissance ou transmission.
          </p>

          <div class="mt-6 space-y-4">
            <div>
              <h4 class="text-sm font-semibold text-marine-800 uppercase tracking-wide mb-2">Structuration stratégique</h4>
              <ul class="space-y-2 text-sm text-marine-800/70">
                <li class="flex items-start gap-2"><span class="text-vert-400 mt-0.5">•</span>Chaîne de valeur & matrices de (double) matérialité</li>
                <li class="flex items-start gap-2"><span class="text-vert-400 mt-0.5">•</span>Raison d'être et engagements stratégiques long terme</li>
                <li class="flex items-start gap-2"><span class="text-vert-400 mt-0.5">•</span>Construction de feuilles de route RSE opérationnelles</li>
                <li class="flex items-start gap-2"><span class="text-vert-400 mt-0.5">•</span>Gouvernance adaptée, société à mission, Ecovadis, B Corp, CSRD</li>
                <li class="flex items-start gap-2"><span class="text-vert-400 mt-0.5">•</span>Résilience du modèle d'affaires / analyse de prospective</li>
                <li class="flex items-start gap-2"><span class="text-vert-400 mt-0.5">•</span>Lien et alignement avec les partenaires financiers (critères ESG, SLL, management package)</li>
              </ul>
            </div>
            <div>
              <h4 class="text-sm font-semibold text-marine-800 uppercase tracking-wide mb-2">Mise en œuvre</h4>
              <ul class="space-y-2 text-sm text-marine-800/70">
                <li class="flex items-start gap-2"><span class="text-vert-400 mt-0.5">•</span>Bilan carbone, stratégie de décarbonation</li>
                <li class="flex items-start gap-2"><span class="text-vert-400 mt-0.5">•</span>Feuille de route RH, baromètre social, marque employeur</li>
                <li class="flex items-start gap-2"><span class="text-vert-400 mt-0.5">•</span>Politique handicap</li>
                <li class="flex items-start gap-2"><span class="text-vert-400 mt-0.5">•</span>Achats responsables / éthique des affaires</li>
                <li class="flex items-start gap-2"><span class="text-vert-400 mt-0.5">•</span>Formation et sensibilisation des équipes</li>
              </ul>
            </div>
          </div>

          <div class="mt-6 pt-4 border-t border-gris-200 mt-auto">
            <p class="text-xs text-marine-800/50">Mission initiale de 6 à 12 mois • Min. 1 jour/semaine • Hybride présentiel/distanciel</p>
          </div>
        </article>

        <!-- Offre Investisseurs -->
        <article class="card reveal p-8 flex flex-col transition-shadow duration-300 hover:shadow-soft" style="--delay:120ms">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-corail-200 mb-4">
            <svg class="w-6 h-6 text-marine-800" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-marine-800">Accompagnement opérationnel ESG / Impact</h3>
          <p class="mt-2 text-sm font-medium text-corail-600">Pour les investisseurs</p>
          <p class="mt-4 text-marine-800/70">
            Acteurs du capital-investissement : fonds PE, family offices, VC, infra.
          </p>

          <div class="mt-6 space-y-4">
            <div>
              <h4 class="text-sm font-semibold text-marine-800 uppercase tracking-wide mb-2">Notre rôle</h4>
              <ul class="space-y-2 text-sm text-marine-800/70">
                <li class="flex items-start gap-2"><span class="text-corail-400 mt-0.5">•</span>Operating Partner ESG externalisé</li>
                <li class="flex items-start gap-2"><span class="text-corail-400 mt-0.5">•</span>Accompagnement de la due diligence jusqu'à l'exit</li>
                <li class="flex items-start gap-2"><span class="text-corail-400 mt-0.5">•</span>Élaboration de plans de création de valeur durable</li>
                <li class="flex items-start gap-2"><span class="text-corail-400 mt-0.5">•</span>Due diligence ESG</li>
                <li class="flex items-start gap-2"><span class="text-corail-400 mt-0.5">•</span>Assistance à la réalisation des chantiers jugés prioritaires</li>
              </ul>
            </div>
            <div>
              <h4 class="text-sm font-semibold text-marine-800 uppercase tracking-wide mb-2">Interventions spécifiques</h4>
              <ul class="space-y-2 text-sm text-marine-800/70">
                <li class="flex items-start gap-2"><span class="text-corail-400 mt-0.5">•</span>PMO pour des projets à impact natif</li>
                <li class="flex items-start gap-2"><span class="text-corail-400 mt-0.5">•</span>Réponse à appel d'offres pour la création de fonds à impact</li>
                <li class="flex items-start gap-2"><span class="text-corail-400 mt-0.5">•</span>Coordination avec prestataires externes</li>
                <li class="flex items-start gap-2"><span class="text-corail-400 mt-0.5">•</span>Suivi des missions et transmission des sujets</li>
                <li class="flex items-start gap-2"><span class="text-corail-400 mt-0.5">•</span>Participation à des comités ESG / Impact / d'investissement</li>
              </ul>
            </div>
          </div>

          <div class="mt-6 pt-4 border-t border-gris-200 mt-auto">
            <p class="text-xs text-marine-800/50">Min. 1 jour/semaine • 12 mois minimum • Compatible avec la présence d'un OP ESG salarié</p>
          </div>
        </article>
      </div>
    </Section>

    <!-- CTA intermédiaire -->
    <div class="bg-marine-800 py-12">
      <div class="mx-auto w-full max-w-6xl px-6 lg:px-10 text-center reveal">
        <p class="text-xl sm:text-2xl text-white font-semibold">Un projet de transformation ? Une question ?</p>
        <a href="#contact" class="btn btn-primary mt-6 text-base px-8 py-4">Parlons-en</a>
      </div>
    </div>

    <!-- ÉQUIPE -->
    <Section id="equipe" title="L'équipe Komizo" tone="default">
      <TeamGrid />

      <!-- Rejoindre le collectif -->
      <div id="collectif" class="mt-16 rounded-2xl bg-marine-800 p-8 text-white reveal">
        <h3 class="text-xl font-semibold text-white mb-3">Pourquoi rejoindre le collectif ?</h3>
        <p class="text-white/80 mb-4">
          Une alternative au cabinet classique et au freelance isolé.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <div class="rounded-lg bg-white/10 p-4">
            <p class="text-sm font-semibold text-vert-400">Missions booster</p>
            <p class="text-xs text-white/70 mt-1">Développement professionnel</p>
          </div>
          <div class="rounded-lg bg-white/10 p-4">
            <p class="text-sm font-semibold text-vert-400">Support collectif</p>
            <p class="text-xs text-white/70 mt-1">Engagement d'un cabinet</p>
          </div>
          <div class="rounded-lg bg-white/10 p-4">
            <p class="text-sm font-semibold text-vert-400">Sécurité financière</p>
            <p class="text-xs text-white/70 mt-1">Gap réduit TJM/revenus</p>
          </div>
          <div class="rounded-lg bg-white/10 p-4">
            <p class="text-sm font-semibold text-vert-400">Liberté</p>
            <p class="text-xs text-white/70 mt-1">Choix des missions</p>
          </div>
        </div>
        <a href="#contact" class="btn btn-primary mt-6">Rejoindre le collectif</a>
      </div>
    </Section>

    <!-- RÉFÉRENCES -->
    <Section id="references" title="Références" subtitle="Des collaborations concrètes, mesurables et de long terme." tone="muted">
      <div class="relative">
        <!-- Carousel Navigation Arrows -->
        <button id="refs-prev" type="button" class="absolute -left-4 sm:-left-6 top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full bg-white shadow-soft border border-gris-200 flex items-center justify-center text-marine-800 hover:bg-vert-100 hover:text-vert-600 transition-colors disabled:opacity-30 disabled:cursor-not-allowed" aria-label="Référence précédente">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        </button>
        <button id="refs-next" type="button" class="absolute -right-4 sm:-right-6 top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full bg-white shadow-soft border border-gris-200 flex items-center justify-center text-marine-800 hover:bg-vert-100 hover:text-vert-600 transition-colors disabled:opacity-30 disabled:cursor-not-allowed" aria-label="Référence suivante">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </button>

        <div id="refs-carousel" class="overflow-hidden">
          <div id="refs-track" class="transition-transform duration-500 ease-in-out">
            {references.map((ref, i) => (
              <article class="card p-8 refs-slide" data-index={i} style={i > 0 ? 'display:none' : ''}>
                <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.2fr] gap-8">
                  <div>
                    <div class="inline-flex items-center gap-2 mb-3">
                      <span class="inline-block w-2 h-2 rounded-full bg-vert-400"></span>
                      <span class="text-sm font-semibold text-vert-600">{ref.sector}</span>
                    </div>
                    <p class="text-sm text-marine-800/60">{ref.detail}</p>
                    <p class="mt-3 text-sm font-medium text-marine-800">{ref.enjeu}</p>
                    <p class="mt-2 text-sm text-marine-800/70">{ref.intervention}</p>
                    <div class="mt-4 inline-flex items-center gap-2 rounded-lg bg-vert-100 px-3 py-2">
                      <svg class="w-4 h-4 text-vert-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      <span class="text-sm font-medium text-vert-600">{ref.resultat}</span>
                    </div>
                  </div>
                  <div class="rounded-xl bg-gris-100 p-6 flex flex-col justify-center">
                    <blockquote class="text-sm sm:text-base text-marine-800/80 italic leading-relaxed">
                      "{ref.verbatim}"
                    </blockquote>
                    <p class="mt-4 text-sm font-semibold text-marine-800">— {ref.auteur}</p>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>

        <!-- Dots indicator -->
        <div class="flex justify-center gap-2 mt-6">
          {references.map((_, i) => (
            <button type="button" class:list={["refs-dot w-2.5 h-2.5 rounded-full transition-colors", i === 0 ? "bg-vert-400" : "bg-gris-300"]} data-index={i} aria-label={`Référence ${i + 1}`}></button>
          ))}
        </div>
      </div>
    </Section>

    <!-- CONTACT -->
    <Section id="contact" title="Parlons-en" subtitle="Vous avez un projet, une question, une intuition ? Parlons-en." tone="default">
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-[1fr_1.3fr]">
        <div class="reveal space-y-6">
          <div class="space-y-4">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-lg bg-marine-800 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="text-sm text-marine-800/60">Email</p>
                <a href="mailto:corentin@komizo-partners.com" class="text-marine-800 font-medium no-underline hover:text-vert-400">corentin@komizo-partners.com</a>
              </div>
            </div>

            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-lg bg-marine-800 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                </svg>
              </div>
              <div>
                <p class="text-sm text-marine-800/60">LinkedIn</p>
                <a href="https://www.linkedin.com/in/corentindecouty/" target="_blank" rel="noopener noreferrer" class="text-marine-800 font-medium no-underline hover:text-vert-400">linkedin.com/in/corentindecouty</a>
              </div>
            </div>
          </div>
        </div>

        <div class="reveal" style="--delay:80ms">
          <ContactForm />
        </div>
      </div>
    </Section>
  </main>

  <!-- Back to top button -->
  <button
    id="back-to-top"
    type="button"
    class="fixed bottom-6 right-6 z-40 hidden w-11 h-11 rounded-full bg-marine-800 text-white shadow-soft items-center justify-center transition-all duration-300 hover:bg-vert-400 focus:outline-none focus:ring-2 focus:ring-vert-400"
    aria-label="Retour en haut"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
    </svg>
  </button>

  <footer class="bg-marine-800 py-14 border-t border-white/10">
    <div class="mx-auto w-full max-w-6xl px-6 lg:px-10">
      <div class="grid grid-cols-1 gap-10 md:grid-cols-3">
        <!-- Col 1: Logo + raison d'être -->
        <div>
          <img src={logoUrl} alt="Komizo Partners" width="120" height="42" class="h-8 w-auto opacity-90 mb-4" />
          <p class="text-sm text-white/60 leading-relaxed">
            Société à mission — Mettre l'économie et la finance au service du vivant.
          </p>
        </div>

        <!-- Col 2: Navigation -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-white/40 mb-4">Navigation</p>
          <ul class="space-y-2">
            <li><a href="#apropos" class="text-sm text-white/70 no-underline hover:text-vert-400">À propos</a></li>
            <li><a href="#offres" class="text-sm text-white/70 no-underline hover:text-vert-400">Nos offres</a></li>
            <li><a href="#equipe" class="text-sm text-white/70 no-underline hover:text-vert-400">L'équipe</a></li>
            <li><a href="#references" class="text-sm text-white/70 no-underline hover:text-vert-400">Références</a></li>
            <li><a href="#contact" class="text-sm text-white/70 no-underline hover:text-vert-400">Contact</a></li>
          </ul>
        </div>

        <!-- Col 3: Contact + liens -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-white/40 mb-4">Contact</p>
          <ul class="space-y-2">
            <li>
              <a href="mailto:corentin@komizo-partners.com" class="text-sm text-white/70 no-underline hover:text-vert-400 inline-flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                corentin@komizo-partners.com
              </a>
            </li>
            <li>
              <a href="https://www.linkedin.com/in/corentindecouty/" target="_blank" rel="noopener noreferrer" class="text-sm text-white/70 no-underline hover:text-vert-400 inline-flex items-center gap-2">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                LinkedIn
              </a>
            </li>
          </ul>
        </div>
      </div>

      <div class="mt-10 pt-6 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-xs text-white/40">
          © {new Date().getFullYear()} Komizo Partners — SASU à mission • Lyon, France
        </p>
        <div class="flex items-center gap-4">
          <a href="#contact" class="text-xs text-white/40 no-underline hover:text-white/70">Mentions légales</a>
          <a href="#contact" class="text-xs text-white/40 no-underline hover:text-white/70">Politique de confidentialité</a>
        </div>
      </div>
    </div>
  </footer>
</BaseLayout>
