            <!-- Duplicate set 2 for seamless loop -->
            <img src={`${base}images/logos/clients/siparex.svg`} alt="Siparex" loading="lazy" class="logo-siparex" />
            <img src={`${base}images/logos/clients/xange.webp`} alt="XAnge" loading="lazy" />
            <img src={`${base}images/logos/clients/meridiam.webp`} alt="Meridiam" loading="lazy" class="logo-meridiam" />
            <img src={`${base}images/logos/clients/evolem.png`} alt="Evolem" loading="lazy" class="logo-evolem" />
            <img src={`${base}images/logos/clients/destia.webp`} alt="Destia" loading="lazy" />
            <img src={`${base}images/logos/clients/piercan.webp`} alt="Piercan" loading="lazy" />
            <img src={`${base}images/logos/clients/welcoop.webp`} alt="Welcoop" loading="lazy" />
            <img src={`${base}images/logos/clients/ratp-dev.webp`} alt="RATP Dev" loading="lazy" />
            <img src={`${base}images/logos/clients/mutualite-francaise.png`} alt="Mutualité Française" loading="lazy" class="logo-mutualite" />
            <img src={`${base}images/logos/clients/bpi.png`} alt="Bpifrance" loading="lazy" />
            <img src={`${base}images/logos/clients/anru.png`} alt="ANRU" loading="lazy" />
            <img src={`${base}images/logos/clients/altema.png`} alt="Altema" loading="lazy" />
            <img src={`${base}images/logos/clients/sodikart.webp`} alt="Sodikart" loading="lazy" class="logo-sodikart" />
            <img src={`${base}images/logos/clients/odontolia.png`} alt="Odontolia" loading="lazy" />
            <img src={`${base}images/logos/clients/lbm.webp`} alt="Labellemontagne" loading="lazy" class="logo-lbm" />
            <img src={`${base}images/logos/clients/lauralu.png`} alt="Lauralu" loading="lazy" />
            <img src={`${base}images/logos/clients/sedia.webp`} alt="Sedia" loading="lazy" />
            <img src={`${base}images/logos/clients/golocal.png`} alt="Golocal" loading="lazy" />
            <img src={`${base}images/logos/clients/lri.webp`} alt="LRI" loading="lazy" />
            <img src={`${base}images/logos/clients/yci-sante.webp`} alt="Yci Santé" loading="lazy" />
            <!-- Duplicate set 3 for extra coverage -->
            <img src={`${base}images/logos/clients/siparex.svg`} alt="Siparex" loading="lazy" class="logo-siparex" />
            <img src={`${base}images/logos/clients/xange.webp`} alt="XAnge" loading="lazy" />
            <img src={`${base}images/logos/clients/meridiam.webp`} alt="Meridiam" loading="lazy" class="logo-meridiam" />
            <img src={`${base}images/logos/clients/evolem.png`} alt="Evolem" loading="lazy" class="logo-evolem" />
            <img src={`${base}images/logos/clients/destia.webp`} alt="Destia" loading="lazy" />
            <img src={`${base}images/logos/clients/piercan.webp`} alt="Piercan" loading="lazy" />
            <img src={`${base}images/logos/clients/welcoop.webp`} alt="Welcoop" loading="lazy" />
            <img src={`${base}images/logos/clients/ratp-dev.webp`} alt="RATP Dev" loading="lazy" />
            <img src={`${base}images/logos/clients/mutualite-francaise.png`} alt="Mutualité Française" loading="lazy" class="logo-mutualite" />
            <img src={`${base}images/logos/clients/bpi.png`} alt="Bpifrance" loading="lazy" />
            <img src={`${base}images/logos/clients/anru.png`} alt="ANRU" loading="lazy" />
            <img src={`${base}images/logos/clients/altema.png`} alt="Altema" loading="lazy" />
            <img src={`${base}images/logos/clients/sodikart.webp`} alt="Sodikart" loading="lazy" class="logo-sodikart" />
            <img src={`${base}images/logos/clients/odontolia.png`} alt="Odontolia" loading="lazy" />
            <img src={`${base}images/logos/clients/lbm.webp`} alt="Labellemontagne" loading="lazy" class="logo-lbm" />
            <img src={`${base}images/logos/clients/lauralu.png`} alt="Lauralu" loading="lazy" />
            <img src={`${base}images/logos/clients/sedia.webp`} alt="Sedia" loading="lazy" />
            <img src={`${base}images/logos/clients/golocal.png`} alt="Golocal" loading="lazy" />
            <img src={`${base}images/logos/clients/lri.webp`} alt="LRI" loading="lazy" />
            <img src={`${base}images/logos/clients/yci-sante.webp`} alt="Yci Santé" loading="lazy" />
          </div>
        </div>
      </div>
    </div>

    <!-- À PROPOS -->
    <Section id="apropos" title="Qui sommes-nous" tone="default">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2">
        <div class="space-y-5 text-base sm:text-lg reveal">
          <p>
            <strong class="text-marine-800">Komizo</strong> est une société à mission à taille humaine, née en 2022 et basée à Lyon.
            Notre raison d'être est de <strong>mettre l'économie et la finance au service du vivant</strong>.
          </p>
          <p>
            Komizo accompagne des PME-ETI, sociétés de gestion et projets à impact de manière
            stratégique et opérationnelle en (ré)intégrant les enjeux écologiques et sociaux au
            cœur de leurs activités.
          </p>
          <p>
            Partenaires de confiance sur la durée, nous facilitons la conduite du changement à
            tous les niveaux, de manière concrète et pragmatique, en nous adaptant au contexte de
            chacun et en favorisant la coopération en interne et avec l'écosystème.
          </p>
        </div>

        <div class="space-y-6 reveal" style="--delay:120ms">
          <div class="rounded-2xl bg-vert-100 p-8">
            <h3 class="text-xl font-semibold text-marine-800 mb-4">Ce qui nous distingue</h3>
            <p class="text-marine-800/70">
              Contrairement aux cabinets classiques, nous intervenons généralement en immersion — une à deux journées par semaine, sur plusieurs années, à la frontière de la finance et de l'opérationnel — avec un interlocuteur senior dédié, appuyé par un réseau de partenaires spécialisés.
            </p>
          </div>

          <div class="flex flex-wrap gap-2">
            <span class="inline-flex items-center rounded-full bg-marine-800/5 px-3 py-1 text-xs font-medium text-marine-800">Écoute active</span>
            <span class="inline-flex items-center rounded-full bg-marine-800/5 px-3 py-1 text-xs font-medium text-marine-800">Non dogmatique</span>
            <span class="inline-flex items-center rounded-full bg-marine-800/5 px-3 py-1 text-xs font-medium text-marine-800">Apporteurs de sens</span>
            <span class="inline-flex items-center rounded-full bg-marine-800/5 px-3 py-1 text-xs font-medium text-marine-800">Bousculeurs bienveillants</span>
          </div>

          <p class="text-sm italic text-marine-800/60">
            Komizo signifie « prendre soin » en grec ancien.
          </p>
        </div>
      </div>
    </Section>

    <!-- ÉQUIPE -->
    <Section id="equipe" title="L'équipe Komizo" tone="muted">
      <TeamGrid />

      <!-- Rejoindre les partenaires -->
      <div id="partenaires" class="mt-16 rounded-2xl bg-marine-800 p-8 text-white reveal">
        <h3 class="text-xl font-semibold text-white mb-3">Pourquoi devenir partenaire ?</h3>
        <p class="text-white/80 mb-4">
          Une alternative au cabinet classique et au freelance isolé.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <div class="rounded-lg bg-white/10 p-4">
            <p class="text-sm font-semibold text-vert-400">Missions booster</p>
            <p class="text-xs text-white/70 mt-1">Développement professionnel</p>
          </div>
          <div class="rounded-lg bg-white/10 p-4">
            <p class="text-sm font-semibold text-vert-400">Support collectif</p>
            <p class="text-xs text-white/70 mt-1">Engagement d'un cabinet</p>
          </div>
          <div class="rounded-lg bg-white/10 p-4">
            <p class="text-sm font-semibold text-vert-400">Sécurité financière</p>
            <p class="text-xs text-white/70 mt-1">Gap réduit TJM/revenus</p>
          </div>
          <div class="rounded-lg bg-white/10 p-4">
            <p class="text-sm font-semibold text-vert-400">Liberté</p>
            <p class="text-xs text-white/70 mt-1">Choix des missions</p>
          </div>
        </div>
        <a href="#contact" class="btn btn-primary mt-6">Rejoindre les partenaires</a>
      </div>
    </Section>

    <!-- OFFRES -->
    <Section id="offres" title="Nos offres" subtitle="Deux expertises complémentaires au service de la transformation durable" tone="default">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8 items-start">

        <!-- Offre 1 : Dirigeants PME-ETI -->
        <article class="card reveal p-0 overflow-hidden transition-shadow duration-300 hover:shadow-soft flex flex-col">
          <div class="bg-vert-400 px-8 pt-8 pb-6 lg:px-10 lg:pt-10">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-white/20 mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="text-2xl font-semibold text-white">Transformation durable et performance</h3>
            <p class="mt-2 text-sm font-medium text-white/80">Pour les dirigeants de PME-ETI en phase de transformation, croissance ou transmission</p>
          </div>

          <div class="px-8 pt-6 pb-8 lg:px-10 lg:pb-10 flex flex-col flex-1">
            <div class="space-y-3">
              <div class="rounded-lg bg-vert-100/60 px-4 py-3 border-l-3 border-l-vert-400">
                <p class="text-sm font-semibold text-marine-800">Pour mieux piloter vos impacts, risques et opportunités dans un monde imprévisible.</p>
              </div>
              <div class="rounded-lg bg-vert-100/60 px-4 py-3 border-l-3 border-l-vert-400">
                <p class="text-sm font-semibold text-marine-800">Pour renforcer l'engagement des équipes, la marque employeur et les relations avec vos parties prenantes clés.</p>
              </div>
              <div class="rounded-lg bg-vert-100/60 px-4 py-3 border-l-3 border-l-vert-400">
                <p class="text-sm font-semibold text-marine-800">Pour sécuriser des contrats grands comptes, créer de nouvelles lignes produits/services et réduire les coûts.</p>
              </div>
            </div>

            <div class="mt-6 space-y-3 text-sm text-marine-800/70">
              <div class="flex items-start gap-3">
                <svg class="w-4 h-4 flex-shrink-0 text-vert-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span>Chaîne de valeur & matrices de (double) matérialité</span>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-4 h-4 flex-shrink-0 text-vert-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span>Résilience du modèle d'affaires / analyse de prospective</span>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-4 h-4 flex-shrink-0 text-vert-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span>Raison d'être et engagements stratégiques long terme</span>
