---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Section from '../components/Section.astro';
import TeamGrid from '../components/TeamGrid.astro';
import ContactForm from '../components/ContactForm.astro';

const base = import.meta.env.BASE_URL;
const heroImage = `${base}images/hero/hero-bg.webp`;
const logoUrl = `${base}images/logos/komizo-logo-blanc.png`;

const references = [
  {
    sector: 'Destia — Aide à domicile',
    detail: 'Leader français, 10 000 salariés, accompagnée par des fonds de private equity',
    enjeu: 'Accompagnement à la transformation en société à mission (depuis 2022)',
    intervention: 'Animation d\'un groupe RSE, co-construction d\'une raison d\'être et d\'engagements stratégiques, structuration business x ESG 360°',
    resultat: 'Amélioration du bien-être des auxiliaires de vie (73% → 78%), baisse significative du turnover et de l\'absentéisme',
    verbatim: 'L\'accompagnement de Komizo a été un catalyseur essentiel pour nous, non seulement dans notre engagement à devenir une référence en matière d\'aide à domicile, mais aussi dans notre transformation en société à mission. Komizo nous challenge beaucoup, et ce de manière intelligente : c\'est ce qu\'on aime !',
    auteur: 'Xavier Mura, Président'
  },
  {
    sector: 'Piercan — PME industrielle',
    detail: '250 salariés, leader mondial de la production de gants de boîtes à gants, sous private equity',
    enjeu: 'Accompagnement à la transformation durable (depuis 2023)',
    intervention: 'Sensibilisation à tous les niveaux, structuration de la politique RSE, création et animation d\'un comité RSE',
    resultat: 'Réduction de 29% de l\'intensité carbone, développement de l\'éco-conception, embarquement de la filiale US',
    verbatim: 'Komizo est un véritable catalyseur de la transformation environnementale et sociale. Leur approche nous aide à structurer notre stratégie RSE de manière concrète et pragmatique. La combinaison de nos énergies nous insuffle un dynamisme puissant et inspirant pour motiver l\'ensemble des collaborateurs, y compris notre filiale américaine.',
    auteur: 'Virginie Bonneau, Directrice QHSE et RSE'
  },
  {
    sector: 'Siparex — Private equity — 4 Mds€ sous gestion',
    detail: 'Acteur indépendant du capital-investissement',
    enjeu: 'Accompagnement opérationnel du fonds ETI (depuis 2023)',
    intervention: 'Operating Partner ESG externalisé pour dix participations, depuis le sourcing jusqu\'à l\'exit',
    resultat: 'Création de valeur durable, meilleur pilotage des risques et opportunités',
    verbatim: 'Komizo travaille avec nous en tant que référent ESG opérationnel pour dix de nos participations. Leur approche est engagée, pragmatique et business. Ils interviennent depuis le sourcing jusqu\'au suivi opérationnel. Komizo travaille comme partenaire de confiance, avec un vrai rôle d\'Operating Partner externalisé.',
    auteur: 'Florent Lauzet, Partner'
  },
  {
    sector: 'Meridiam — Infrastructures durables — 20 Mds€ sous gestion',
    detail: 'Société d\'investissement indépendante à mission',
    enjeu: 'Création et déploiement d\'une société de projet à impact (depuis 2023)',
    intervention: 'Chefferie de projet d\'un consortium public-privé, rôle de Direction du développement',
    resultat: 'Lancement opérationnel de la société de projet',
    verbatim: 'Grâce aux compétences économico-financières de Corentin, à son énergie communicative et à sa capacité à animer un projet collectif, nous sommes proches du lancement opérationnel de ce projet particulièrement difficile et ambitieux.',
    auteur: 'Olivier Noblecourt, Directeur de l\'investissement local et durable'
  },
  {
    sector: 'XAnge — VC — 700M€ sous gestion',
    detail: 'Fonds d\'investissement early-stage européen',
    enjeu: 'Création et déploiement du fonds Mutuelles Impact (depuis 2019)',
    intervention: 'Lead sur la réponse à appel d\'offres (remporté), structuration du fonds, Operating Partner Impact',
    resultat: 'Gain de l\'appel d\'offres, développement de la thématique impact x santé (près de 100 M€ sous gestion)',
    verbatim: 'L\'implication de Corentin a été précieuse dès la phase de l\'appel d\'offres. Corentin nous a accompagné dans l\'analyse d\'opportunités d\'investissement, la construction et le suivi de feuilles de route impact.',
    auteur: 'Andréas Gall, Directeur Général Délégué'
  }
];

const engagements = [
  { title: 'Mesure d\'impact', detail: 'Progression mesurée avant, pendant, après — résultats publiés dans notre rapport de mission annuel' },
  { title: 'Impact au board', detail: 'À l\'ordre du jour du board et des équipes, pas seulement dans un rapport' },
  { title: 'Autonomie client', detail: 'Monter en compétences nos clients — notre objectif : les rendre autonomes' },
  { title: 'Équilibre d\'équipe', detail: 'Prendre soin de notre équilibre pour durer — sans équipe solide, pas d\'accompagnement de qualité' },
  { title: 'Zéro vol en Europe', detail: 'Pour tous nos déplacements professionnels' },
  { title: '1 événement / an', detail: 'Pour essaimer au-delà de nos missions' },
];

const comiteMission = [
  {
    name: 'Anaïs Picard',
    role: 'Impact & Société à mission',
    photo: `${base}images/team/comite-mission/anais-picard.webp`,
    bio: 'Ex Chief Sustainability Officer, KEM ONE. 10 ans au sein du Groupe Rocher, qu\'elle a accompagné jusqu\'à devenir le premier groupe international société à mission. Diplômée d\'emlyon et formée en prospective.'
  },
  {
    name: 'Alice Morillon',
    role: 'ESG & Private Equity',
    photo: `${base}images/team/comite-mission/alice-morillon.webp`,
    bio: 'Head of Sustainability & Impact, Archimed. Fondatrice de l\'équipe ESG-Impact d\'Archimed, leader mondial du capital-investissement en santé. Parcours en entrepreneuriat social en Asie et en conseil Sustainability chez PwC.'
  },
  {
    name: 'Michel du Peloux',
    role: 'Santé & Management',
    photo: `${base}images/team/comite-mission/michel-du-peloux.webp`,
    bio: 'Médecin. Ancien dirigeant de groupes internationaux de santé (Merck, Mérieux Nutrisciences), aujourd\'hui engagé sur le sujet de la santé mentale chez les étudiants. Double culture médecine et management.'
  },
  {
    name: 'Guillaume Rebaudet',
    role: 'Private Equity & Entrepreneuriat',
    photo: `${base}images/team/comite-mission/guillaume-rebaudet.webp`,
    bio: 'Partner, Siparex ETI. 15 ans chez Siparex. Premier à avoir fait confiance à Komizo en 2019 pour accompagner la création d\'un fonds à impact et la transformation de PME-ETI sous LBO.'
  }
];
---

<BaseLayout>
  <Header />

  <!-- Scroll progress bar -->
  <div id="scroll-progress" class="fixed top-0 left-0 h-[3px] bg-vert-400 z-50 transition-none" style="width:0%"></div>

  <main id="main-content" class="pt-16">

    <!-- HERO -->
    <section id="hero" class="section-anchor relative bg-marine-800 py-28 sm:py-36 overflow-hidden">
      <div class="absolute inset-0" aria-hidden="true">
        <img src={heroImage} alt="" class="h-full w-full object-cover opacity-25" />
        <div class="absolute inset-0 bg-gradient-to-r from-marine-800/90 via-marine-800/70 to-marine-800/50"></div>
      </div>
      <div class="relative mx-auto w-full max-w-6xl px-6 lg:px-10">
        <div class="reveal max-w-3xl">
          <img src={logoUrl} alt="Komizo Partners" width="200" height="70" class="h-12 w-auto mb-10 opacity-90" />
          <h1 class="text-4xl sm:text-5xl lg:text-6xl text-white font-bold leading-[1.1]">
            Des PME solides<br />dans un monde instable
          </h1>
          <p class="mt-8 max-w-2xl text-lg sm:text-xl text-white/75 leading-relaxed">
            Nous accompagnons PME-ETI et investisseurs sur le temps long pour renforcer durablement leur performance en intégrant l'impact au cœur du modèle d'affaires.
          </p>
          <div class="mt-12 flex flex-col sm:flex-row flex-wrap gap-4">
            <a href="#contact" class="btn btn-primary text-base px-8 py-4 text-center">Nous contacter</a>
            <a href="#partenaires" class="btn btn-secondary border-white/30 text-white hover:bg-white/10 hover:border-white text-base px-8 py-4 text-center">Rejoindre les partenaires</a>
          </div>
        </div>
      </div>
    </section>

    <!-- BANDE LOGOS CONFIANCE — marquee infini -->
    <div class="bg-white border-b border-gris-200 overflow-hidden">
      <div class="py-8">
        <p class="text-[11px] font-semibold uppercase tracking-widest text-gris-400 text-center mb-6">Ils nous font confiance</p>
        <div class="logos-marquee">
          <div class="logos-track">
            <img src={`${base}images/logos/clients/siparex.svg`} alt="Siparex" loading="lazy" class="logo-siparex" />
            <img src={`${base}images/logos/clients/xange.webp`} alt="XAnge" loading="lazy" />
            <img src={`${base}images/logos/clients/meridiam.webp`} alt="Meridiam" loading="lazy" class="logo-meridiam" />
            <img src={`${base}images/logos/clients/evolem.png`} alt="Evolem" loading="lazy" class="logo-evolem" />
            <img src={`${base}images/logos/clients/destia.webp`} alt="Destia" loading="lazy" />
            <img src={`${base}images/logos/clients/piercan.webp`} alt="Piercan" loading="lazy" />
            <img src={`${base}images/logos/clients/welcoop.webp`} alt="Welcoop" loading="lazy" />
            <img src={`${base}images/logos/clients/ratp-dev.webp`} alt="RATP Dev" loading="lazy" />
            <img src={`${base}images/logos/clients/mutualite-francaise.png`} alt="Mutualité Française" loading="lazy" class="logo-mutualite" />
            <img src={`${base}images/logos/clients/bpi.png`} alt="Bpifrance" loading="lazy" />
            <img src={`${base}images/logos/clients/anru.png`} alt="ANRU" loading="lazy" />
            <img src={`${base}images/logos/clients/altema.png`} alt="Altema" loading="lazy" />
            <img src={`${base}images/logos/clients/sodikart.webp`} alt="Sodikart" loading="lazy" class="logo-sodikart" />
            <img src={`${base}images/logos/clients/odontolia.png`} alt="Odontolia" loading="lazy" />
            <img src={`${base}images/logos/clients/lbm.webp`} alt="Labellemontagne" loading="lazy" class="logo-lbm" />
            <img src={`${base}images/logos/clients/lauralu.png`} alt="Lauralu" loading="lazy" />
            <img src={`${base}images/logos/clients/sedia.webp`} alt="Sedia" loading="lazy" />
            <img src={`${base}images/logos/clients/golocal.png`} alt="Golocal" loading="lazy" />
            <img src={`${base}images/logos/clients/lri.webp`} alt="LRI" loading="lazy" />
