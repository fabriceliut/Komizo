---
const base = import.meta.env.BASE_URL;

const founder = {
  name: 'Corentin Decouty',
  role: 'Fondateur',
  photo: `${base}images/team/corentin.webp`,
  expertise: "Développement d'alliances, pilotage de projets, catalyseur, due diligence stratégique et ESG",
  experience: 'Siparex (ETI, Mutuelles Impact), Meridiam (Yci Santé), Evolem, Destia, Mutualité Française, PMSI Strategy',
  formation: 'ESSEC & Imperial College London',
  bio: "Corentin travaille depuis plus de 12 ans avec des fonds de private equity, dont 5 en lien avec des sujets d'investissement et d'entrepreneuriat à impact. Réputé pour son franc-parler et son pragmatisme, il place les sujets d'ESG et de RSE au cœur de la stratégie et du modèle d'affaires de l'entreprise, en utilisant la finance comme un levier clé de transformation."
};

const partners = [
  {
    name: 'Laura-May',
    role: 'RH, inclusion, handicap',
    photo: `${base}images/team/lauramay.webp`,
    experience: 'Destia, EPSA, Welcoop, RATP Dev'
  },
  {
    name: 'Aurélien',
    role: 'Achats, opérations',
    photo: `${base}images/team/aurelien.webp`,
    experience: 'EPSA, Schneider Electric'
  },
  {
    name: 'Sirine',
    role: 'Direction RSE, Ecovadis',
    photo: `${base}images/team/sirine.webp`,
    experience: 'EPSA, KPMG'
  },
  {
    name: 'Julie',
    role: 'Marketing',
    photo: `${base}images/team/julie.webp`,
    experience: 'Golocal, Goodness&Co, Danone'
  },
  {
    name: 'Gabriel',
    role: 'Circularité, stratégie',
    photo: `${base}images/team/gabriel.webp`,
    experience: 'Talan, Roland Berger'
  },
  {
    name: 'Audrey',
    role: 'Gouvernance, coaching',
    photo: `${base}images/team/audrey.webp`,
    experience: 'Evaneos, Lapeyre, Kiloutou'
  },
  {
    name: 'Caroline',
    role: 'Sensibilisation, stratégie 🇧🇪',
    photo: `${base}images/team/caroline.webp`,
    experience: 'MySezame, Alterna, Mars'
  },
  {
    name: 'Mylène',
    role: 'Communautés, formation',
    photo: `${base}images/team/mylene.webp`,
    experience: 'Haatch, Ecolearn, Danone'
  },
  {
    name: 'Elodie',
    role: 'ESG, finance durable',
    photo: `${base}images/team/elodie.webp`,
    experience: 'Better Way, I&P'
  },
  {
    name: 'Sébastien',
    role: 'R&D, supply chain',
    photo: `${base}images/team/sebastien.webp`,
    experience: 'Renault'
  },
  {
    name: 'Agathe',
    role: 'CSRD',
    photo: `${base}images/team/agathe.webp`,
    experience: 'Thermador, Biomérieux'
  },
];
---

<!-- TIER 1 : Fondateur — mise en avant large -->
<div class="reveal">
  <div class="rounded-2xl border border-gris-200 bg-white overflow-hidden shadow-card">
    <div class="grid grid-cols-1 md:grid-cols-[280px_1fr] lg:grid-cols-[320px_1fr] gap-0">
      <div class="aspect-square md:aspect-auto">
        <img
          src={founder.photo}
          alt={`Portrait de ${founder.name}`}
          width="800"
          height="800"
          loading="lazy"
          decoding="async"
          class="h-full w-full object-cover"
        />
      </div>
      <div class="p-8 flex flex-col justify-center">
        <p class="text-xs font-semibold uppercase tracking-widest text-vert-600 mb-2">{founder.role}</p>
        <h3 class="text-3xl font-bold text-marine-800">{founder.name}</h3>
        <p class="mt-4 text-base text-marine-800/75 leading-relaxed">{founder.bio}</p>
        <div class="mt-6 flex flex-wrap gap-2">
          <span class="inline-flex items-center rounded-full bg-vert-100 px-3 py-1 text-xs font-medium text-marine-800">
            {founder.expertise}
          </span>
        </div>
        <p class="mt-3 text-xs text-marine-800/50 italic">{founder.experience}</p>
        <p class="mt-1 text-xs text-marine-800/50">{founder.formation}</p>
      </div>
    </div>
  </div>
</div>

<!-- TIER 2 : Partenaires — tous au même niveau, photos plus petites -->
<div class="mt-12">
  <h3 class="text-lg font-semibold text-marine-800 mb-6 reveal">Partenaires</h3>
  <div class="grid grid-cols-2 gap-5 sm:grid-cols-3 lg:grid-cols-4">
    {partners.map((member, index) => (
      <article class="reveal rounded-2xl border border-gris-200 bg-white overflow-hidden shadow-card transition-shadow hover:shadow-soft" style={`--delay:${index * 70}ms`}>
        <div class="aspect-[4/3]">
          {member.photo.includes('placeholders') ? (
            <div class="h-full w-full bg-gris-100 flex items-center justify-center">
              <div class="w-14 h-14 rounded-full bg-marine-800 flex items-center justify-center text-white text-xl font-semibold">
                {member.name.charAt(0)}
              </div>
            </div>
          ) : (
            <img
              src={member.photo}
              alt={`Portrait de ${member.name}`}
              width="400"
              height="300"
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover transition-transform duration-300 hover:scale-105"
            />
          )}
        </div>
        <div class="p-4 text-center">
          <h3 class="text-base font-semibold text-marine-800">{member.name}</h3>
          <p class="text-xs font-medium text-vert-600 mt-0.5">{member.role}</p>
          <p class="text-xs text-marine-800/50 mt-1 italic">{member.experience}</p>
        </div>
      </article>
    ))}
    <div class="reveal rounded-2xl border-2 border-dashed border-vert-400/30 flex items-center justify-center p-6" style="--delay:400ms">
      <p class="text-xs text-vert-500 text-center font-medium">+ d'autres experts<br />selon vos besoins</p>
    </div>
  </div>
</div>
