---
const formEndpoint = 'https://formsubmit.co/corentin@komizo-partners.com';
---

<form id="contact-form" action={formEndpoint} method="POST" class="space-y-5">
  <input type="hidden" name="_subject" value="Nouveau message depuis komizo-partners.com" />
  <input type="hidden" name="_captcha" value="true" />
  <input type="hidden" name="_next" value="https://fabriceliut.github.io/Komizo/#contact" />
  <input type="text" name="_honey" style="display:none" />
  <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
    <div>
      <label for="name" class="mb-1.5 block text-sm font-medium text-marine-800">Nom *</label>
      <input id="name" name="name" type="text" autocomplete="name" required class="input-field" placeholder="Votre nom" />
    </div>

    <div>
      <label for="email" class="mb-1.5 block text-sm font-medium text-marine-800">Email *</label>
      <input id="email" name="email" type="email" autocomplete="email" required class="input-field" placeholder="votre@email.com" />
    </div>
  </div>

  <div>
    <label for="company" class="mb-1.5 block text-sm font-medium text-marine-800">Entreprise</label>
    <input id="company" name="company" type="text" autocomplete="organization" class="input-field" placeholder="Votre entreprise" />
  </div>

  <div>
    <label for="subject" class="mb-1.5 block text-sm font-medium text-marine-800">Objet *</label>
    <select id="subject" name="subject" required class="input-field">
      <option value="" disabled selected>Choisir un sujet</option>
      <option value="accompagnement-pme">Accompagnement dirigeant PME-ETI</option>
      <option value="operating-partner">Operating Partner ESG / Investisseurs</option>
      <option value="rejoindre">Rejoindre les partenaires Komizo</option>
      <option value="autre">Autre</option>
    </select>
  </div>

  <div>
    <label for="message" class="mb-1.5 block text-sm font-medium text-marine-800">Message *</label>
    <textarea id="message" name="message" rows="5" required class="input-field" placeholder="Décrivez votre projet ou votre question..."></textarea>
  </div>

  <div class="flex items-start gap-3">
    <input id="consent" name="consent" type="checkbox" required
      class="mt-1 h-4 w-4 rounded border-gris-300 text-vert-400 focus:ring-vert-400" />
    <label for="consent" class="text-xs text-marine-800/60">
      En soumettant ce formulaire, j'accepte que mes données soient utilisées pour me recontacter dans le cadre de ma demande. Aucune donnée n'est partagée avec des tiers.
    </label>
  </div>

  <button id="submit-button" type="submit" class="btn btn-primary">
    Envoyer le message
  </button>

  <p id="form-status" class="min-h-[1.5rem] text-sm" role="status" aria-live="polite"></p>
</form>

<script is:inline>
  const form = document.querySelector('#contact-form');
  const status = document.querySelector('#form-status');
  const submitButton = document.querySelector('#submit-button');

  if (form instanceof HTMLFormElement && status instanceof HTMLElement && submitButton instanceof HTMLButtonElement) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const formData = new FormData(form);

      submitButton.disabled = true;
      submitButton.setAttribute('aria-busy', 'true');
      status.textContent = 'Envoi en cours...';
      status.className = 'min-h-[1.5rem] text-sm text-marine-800/60';

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: { Accept: 'application/json' }
        });

        if (response.ok) {
          form.reset();
          status.textContent = 'Merci\u00a0! Votre message a bien \u00e9t\u00e9 envoy\u00e9. Nous reviendrons vers vous rapidement.';
          status.className = 'min-h-[1.5rem] text-sm text-vert-500 font-medium';
        } else {
          status.textContent = 'Une erreur est survenue. Vous pouvez nous \u00e9crire directement \u00e0 corentin@komizo-partners.com';
          status.className = 'min-h-[1.5rem] text-sm text-corail-500';
        }
      } catch {
        status.textContent = 'Impossible d\u2019envoyer le formulaire pour le moment. Merci de r\u00e9essayer plus tard.';
        status.className = 'min-h-[1.5rem] text-sm text-corail-500';
      } finally {
        submitButton.disabled = false;
        submitButton.removeAttribute('aria-busy');
      }
    });
  }
</script>
