---
// TODO: Remplacer par le endpoint Formspree réel.
const formEndpoint = 'https://formspree.io/f/XXXXYYYY';
---

<form id="contact-form" action={formEndpoint} method="POST" class="card space-y-5">
  <div>
    <label for="name" class="mb-1 block text-sm font-semibold text-paper-100">Nom</label>
    <input id="name" name="name" type="text" autocomplete="name" required class="input-field" />
  </div>

  <div>
    <label for="email" class="mb-1 block text-sm font-semibold text-paper-100">Email</label>
    <input id="email" name="email" type="email" autocomplete="email" required class="input-field" />
  </div>

  <div>
    <label for="phone" class="mb-1 block text-sm font-semibold text-paper-100">Téléphone</label>
    <input id="phone" name="phone" type="tel" autocomplete="tel" class="input-field" />
  </div>

  <div>
    <label for="title" class="mb-1 block text-sm font-semibold text-paper-100">Titre</label>
    <input id="title" name="title" type="text" autocomplete="organization-title" class="input-field" />
  </div>

  <div>
    <label for="message" class="mb-1 block text-sm font-semibold text-paper-100">Message</label>
    <textarea id="message" name="message" rows="6" required class="input-field"></textarea>
  </div>

  <button id="submit-button" type="submit" class="btn btn-primary w-full sm:w-auto">Soumettre</button>

  <p id="form-status" class="min-h-[1.5rem] text-sm text-paper-200" role="status" aria-live="polite"></p>
</form>

<script is:inline>
  const form = document.querySelector('#contact-form');
  const status = document.querySelector('#form-status');
  const submitButton = document.querySelector('#submit-button');

  if (form instanceof HTMLFormElement && status instanceof HTMLElement && submitButton instanceof HTMLButtonElement) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const formData = new FormData(form);

      submitButton.disabled = true;
      submitButton.setAttribute('aria-busy', 'true');
      status.textContent = 'Envoi en cours...';

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: {
            Accept: 'application/json'
          }
        });

        if (response.ok) {
          form.reset();
          status.textContent = 'Merci d\u2019avoir compl\u00e9t\u00e9 le formulaire\u00a0!';
          status.classList.remove('text-red-300');
          status.classList.add('text-accent-400');
        } else {
          status.textContent = 'Une erreur est survenue. Merci de r\u00e9essayer ou de nous \u00e9crire par email.';
          status.classList.remove('text-accent-400');
          status.classList.add('text-red-300');
        }
      } catch {
        status.textContent = 'Impossible d\u2019envoyer le formulaire pour le moment. Merci de r\u00e9essayer plus tard.';
        status.classList.remove('text-accent-400');
        status.classList.add('text-red-300');
      } finally {
        submitButton.disabled = false;
        submitButton.removeAttribute('aria-busy');
      }
    });
  }
</script>
