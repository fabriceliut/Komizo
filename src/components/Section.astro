---
interface Props {
  id: string;
  title?: string;
  subtitle?: string;
  tone?: 'default' | 'muted' | 'dark';
  className?: string;
}

const { id, title, subtitle, tone = 'default', className = '' } = Astro.props;

const bgClass = {
  default: 'bg-white',
  muted: 'bg-gris-100',
  dark: 'bg-marine-800 text-white'
}[tone];
---

<section
  id={id}
  class:list={[
    'section-anchor py-20 sm:py-24',
    bgClass,
    className
  ]}
>
  <div class="mx-auto w-full max-w-6xl px-6 lg:px-10">
    {
      (title || subtitle) && (
        <header class="mb-10 sm:mb-12 reveal">
          {title && (
            <div class="flex items-start gap-3">
              <div class="mt-2 flex-shrink-0" aria-hidden="true">
                <svg width="20" height="18" viewBox="0 0 20 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="0" y="6" width="5" height="5" rx="0.5" fill={tone === 'dark' ? '#5cba9b' : '#5cba9b'} />
                  <path d="M5 7.5 L18 3" stroke={tone === 'dark' ? '#5cba9b' : '#5cba9b'} stroke-width="1.2" stroke-linecap="round" opacity="0.9" />
                  <path d="M5 8.5 L19 7" stroke={tone === 'dark' ? '#5cba9b' : '#5cba9b'} stroke-width="1.2" stroke-linecap="round" opacity="0.7" />
                  <path d="M5 9.5 L17 11.5" stroke={tone === 'dark' ? '#5cba9b' : '#5cba9b'} stroke-width="1.2" stroke-linecap="round" opacity="0.5" />
                </svg>
              </div>
              <h2 class:list={["text-3xl sm:text-4xl lg:text-5xl", tone === 'dark' ? 'text-white' : 'text-marine-800']}>{title}</h2>
            </div>
          )}
          {subtitle && <p class:list={["mt-3 max-w-3xl text-base sm:text-lg", tone === 'dark' ? 'text-white/80' : 'text-marine-800/70']}>{subtitle}</p>}
        </header>
      )
    }
    <slot />
  </div>
</section>
