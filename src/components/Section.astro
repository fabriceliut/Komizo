---
interface Props {
  id: string;
  title?: string;
  subtitle?: string;
  tone?: 'default' | 'muted' | 'dark';
  className?: string;
}

const { id, title, subtitle, tone = 'default', className = '' } = Astro.props;

const bgClass = {
  default: 'bg-white',
  muted: 'bg-gris-100',
  dark: 'bg-marine-800 text-white'
}[tone];
---

<section
  id={id}
  class:list={[
    'section-anchor py-20 sm:py-24',
    bgClass,
    className
  ]}
>
  <div class="mx-auto w-full max-w-6xl px-6 lg:px-10">
    {
      (title || subtitle) && (
        <header class="mb-12 sm:mb-14 reveal">
          {title && (
              <h2 class:list={["text-3xl sm:text-4xl lg:text-5xl", tone === 'dark' ? 'text-white' : 'text-marine-800']}>{title}</h2>
          )}
          {subtitle && <p class:list={["mt-4 max-w-3xl text-base sm:text-lg", tone === 'dark' ? 'text-white/80' : 'text-marine-800/60']}>{subtitle}</p>}
        </header>
      )
    }
    <slot />
  </div>
</section>
