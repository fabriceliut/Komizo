---
interface Props {
  id: string;
  title?: string;
  subtitle?: string;
  tone?: 'default' | 'muted';
  className?: string;
}

const { id, title, subtitle, tone = 'default', className = '' } = Astro.props;
---

<section
  id={id}
  class:list={[
    'section-anchor py-20 sm:py-24',
    tone === 'muted' ? 'bg-night-900/55' : 'bg-night-950',
    className
  ]}
>
  <div class="mx-auto w-full max-w-6xl px-6 lg:px-10">
    {
      (title || subtitle) && (
        <header class="mb-10 sm:mb-12 reveal">
          {title && <h2 class="text-3xl sm:text-4xl lg:text-5xl">{title}</h2>}
          {subtitle && <p class="mt-3 max-w-3xl text-base sm:text-lg">{subtitle}</p>}
        </header>
      )
    }
    <slot />
  </div>
</section>
